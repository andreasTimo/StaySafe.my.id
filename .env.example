# ─── StaySafe.my.id Environment Variables Template ───

# Cloudflare Tunnel Token (Phase 3)
# You can get this from the Cloudflare Zero Trust Dashboard → Networks → Tunnels
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# API Base URL (used by Vite during build time)
# For local testing, use: http://localhost:8080 or your local function URL
# For production, use your production domain
VITE_API_BASE_URL=your_api_base_url_here

# API WAF Shared Authentication Key (used for edge WAF challenge)
VITE_API_AUTH_KEY=your_shared_waf_auth_key_here

# Firestore MongoDB Connection String (used by backend functions)
# Format: mongodb://<username>:<password>@<host>:<port>/?ssl=true&...
MONGODB_URI=your_firestore_mongodb_uri_here
